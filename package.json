{
  "name": "bondsports",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "db:init": "ts-node-dev --transpile-only prisma/init.ts",
    "seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "test": "jest",
    "setup": "npm install && npm run prisma:generate && npm run db:init",
    "db:reset": "powershell -NoProfile -Command \"if (Test-Path .\\prisma\\dev.db) { Remove-Item .\\prisma\\dev.db }\" && npm run db:init"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitayMoshe/bondsports.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nitayMoshe/bondsports/issues"
  },
  "homepage": "https://github.com/nitayMoshe/bondsports#readme",
  "dependencies": {
    "@prisma/client": "^6.8.1",
    "express": "^5.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "dotenv": "^17.4.2",
    "jest": "^30.3.0",
    "prisma": "^6.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
